# Porta do servidor (Railway injeta automaticamente — pode ignorar localmente)
PORT=3000

# Auth compartilhada com a Edge Function (gere um UUID v4)
# Esse mesmo valor entra na Lovable Cloud como SERPRO_PROXY_SHARED_SECRET
PROXY_SHARED_SECRET=5b6fe584-b3ed-431a-8f6d-d2a2038efb62

# Ambiente SERPRO: trial | demonstracao | producao
SERPRO_AMBIENTE=trial

# Credenciais OAuth da loja SERPRO (mesmas usadas em /conexoes)
SERPRO_CONSUMER_KEY=sGRI1OqPbcetQSuhiyawWag9MsEa
SERPRO_CONSUMER_SECRET=bGOFcceIilQMfTw8GCKa1fsODl4a

# Caminho do certificado A1 dentro do container.
# No Railway, monte um Volume em /data e suba o cert.pfx lá.
SERPRO_CERT_PATH=/data/G P BIANCO GESTAO DE CONTABILIDADE_44727489000173 12345678.pfx
SERPRO_CERT_PASSWORD=12345678

# CNPJ do escritório contratante (somente dígitos)
CONTRATANTE_CNPJ=44727489000173
# Geralmente = CONTRATANTE_CNPJ. Sobrescreva só se necessário.
AUTOR_PEDIDO_CNPJ=44727489000173
